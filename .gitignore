.ipynb_checkpoints/
**/.ipynb_checkpoints/
notebooks/.local/

# -----------------------------------------------------------------------------
# Airflow (si se usa)
# -----------------------------------------------------------------------------
airflow.db
airflow.cfg
unittests.cfg
logs/
webserver_config.py

# -----------------------------------------------------------------------------
