# =============================================================================
# Spark Match Data Pipeline (05-data-pipeline) - .gitignore
# =============================================================================
# Generado segun ADR-003 branch-based deployment y estandares de la org.
# Version: 1.0.0 - 2026-07-09
# Stack: Python (pandas, Airflow o Prefect, uv)
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg-info/PKG-INFO

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.python-version

# -----------------------------------------------------------------------------
# uv (package manager)
# -----------------------------------------------------------------------------
.uv/
# NOTE: uv.lock IS committed — required for reproducible CI builds (uv sync --frozen).
# Pipeline workflows use `uv sync --frozen` which requires uv.lock in the repo.

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.tox/
.nox/

# -----------------------------------------------------------------------------
# Type checking
# -----------------------------------------------------------------------------
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/

# -----------------------------------------------------------------------------
# Notebooks (cuidado: outputs pueden contener datos sensibles)
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
**/.ipynb_checkpoints/
notebooks/.local/

# -----------------------------------------------------------------------------
# Airflow (si se usa)
# -----------------------------------------------------------------------------
airflow.db
airflow.cfg
unittests.cfg
logs/
webserver_config.py

# -----------------------------------------------------------------------------
# dbt (si se usa)
# -----------------------------------------------------------------------------
dbt_packages/
logs/
target/
user_id.json

# -----------------------------------------------------------------------------
# Variables de entorno
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
**/.env
**/.env.local
!.env.example

# -----------------------------------------------------------------------------
# AWS / GCP / Azure credentials
# -----------------------------------------------------------------------------
.aws/
.gcp/
.azure/
**/credentials.json
**/service-account*.json

# -----------------------------------------------------------------------------
# Data files (NUNCA commitear data cruda)
# -----------------------------------------------------------------------------
data/raw/
data/processed/
data/interim/
data/external/
data/.gitkeep
data/sources/                          # Per-source DVC-tracked outputs
data/canonical/                        # Merged canonical datasets
data/corpus.jsonl                      # RAG corpus (DVC-tracked)
snapshots/
*.csv
*.parquet
*.json.gz
!data/**/*.example.csv
!configs/*.example.json
!data/filtered.csv                      # Legacy files committed pre-DVC (will be removed in Phase 0)
!data/features.csv
!data/feature_config.json
!data/ponte_en_carrera/raw.xlsx          # PEC source raw, tracked pre-DVC (will be DVC-tracked in Phase 2)

# DVC
.dvc/cache/                            # Local DVC cache (data lives in S3 remote)
.dvc/tmp/
.dvcignore                             # Tracked in git
!uv.lock                                # uv.lock IS tracked (reproducible builds)

# -----------------------------------------------------------------------------
# Database local (sqlite, duckdb)
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
*.duckdb

# -----------------------------------------------------------------------------
# IDEs
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.iml

# -----------------------------------------------------------------------------
