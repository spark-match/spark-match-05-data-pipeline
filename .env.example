# =============================================================================
# Environment variables for spark-match-05-data-pipeline
# =============================================================================
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored. CI/GH Actions provide these via GH Secrets per env.
# =============================================================================

# Environment identifier
ENVIRONMENT=dev                            # dev | prod

# Local paths (relative to project root)
DATA_DIR=./data
SNAPSHOT_DIR=./snapshots

# DVC remote - selected by ENVIRONMENT at runtime
DVC_REMOTE=s3-dev
DVC_REMOTE_URL_DEV=s3://spark-match-data-dev/dvc-store
DVC_REMOTE_URL_PROD=s3://spark-match-data-prod/dvc-store

# AWS OIDC roles (populated from `aws-actions/configure-aws-credentials`)
AWS_DVC_DEPLOY_ROLE_ARN_DEV=arn:aws:iam::681526276858:role/spark-match-dvc-deploy-dev
AWS_DVC_DEPLOY_ROLE_ARN_PROD=arn:aws:iam::681526276858:role/spark-match-dvc-deploy-prod

# Logging
LOG_LEVEL=INFO

# Source-specific (Ponte en Carrera — DEPRECATED 2026-07-12, kept for historical runs)
PEC_DOWNLOAD_URL=https://ponteencarrera.minedu.gob.pe/pec-portal-web/inicio/donde-estudiar
PEC_DOWNLOAD_TIMEOUT_SECONDS=60